# Discord webhook URLs for each search (each goes to a different channel)
DISCORD_WEBHOOK_SKETCH=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
DISCORD_WEBHOOK_SUPERFRACTOR=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
DISCORD_WEBHOOK_1OF1=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
DISCORD_WEBHOOK_5=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
DISCORD_WEBHOOK_DBS_GDR=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Webkinz searches (all items use the same webhook)
DISCORD_WEBHOOK_WEBKINZ=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Lorcana card searches (all items use the same webhook)
DISCORD_WEBHOOK_LORCANA=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Riftbound searches
DISCORD_WEBHOOK_RIFTBOUND=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# === PROXY SUPPORT (Recommended to avoid CAPTCHA) ===
# Single proxy (takes precedence over pool)
# PROXY_URL=http://username:password@proxy.example.com:8080

# Proxy pool (comma-separated, rotates on browser restart)
# PROXY_POOL=http://user:pass@proxy1.com:8080,http://user:pass@proxy2.com:8080

# Recommended residential proxy services for eBay:
# - Smartproxy: http://user:pass@us.smartproxy.com:10000
# - Bright Data: http://user:pass@brd.superproxy.io:22225
# - IPRoyal: http://user:pass@geo.iproyal.com:12321

# === OPTIONAL SETTINGS ===
CHECK_INTERVAL=15
BROWSER_RESTART_HOURS=2
MAX_RETRIES=3
HEALTH_CHECK_HOURS=6
HARD_RESTART_THRESHOLD=10
